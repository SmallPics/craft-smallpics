{
	"name": "smallpics/craft-smallpics",
	"type": "craft-plugin",
	"keywords": [
		"smallpics",
		"craftcms",
		"transformer",
		"images",
		"processing"
	],
	"license": "MIT",
	"support": {
		"email": "support@smallpics.io",
		"issues": "https://github.com/smallpics/craft-smallpics/issues?state=open",
		"source": "https://github.com/smallpics/craft-smallpics",
		"docs": "https://github.com/smallpics/craft-smallpics/blob/main/README.md"
	},
	"authors": [
		{
			"name": "Small Pics",
			"homepage": "https://www.smallpics.io"
		}
	],
	"description": "Small Pics image transformer for Craft",
	"extra": {
		"handle": "smallpics",
		"name": "Small Pics",
		"developer": "Small Pics",
		"class": "smallpics\\craft\\Plugin"
	},
	"autoload": {
		"psr-4": {
			"smallpics\\craft\\": "src/"
		}
	},
	"require": {
		"php": "^8.1",
		"craftcms/cms": "^4.5|^5.0.0",
		"smallpics/smallpics-php": "^1.0.3"
	},
	"require-dev": {
		"fostercommerce/ecs": "dev-main",
		"fostercommerce/rector": "v2.x-dev",
		"phpstan/phpstan": "^2.0"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"allow-plugins": {
			"craftcms/plugin-installer": true,
			"yiisoft/yii2-composer": true
		}
	},
	"scripts": {
		"phpstan": "phpstan --memory-limit=1G",
		"ecs:check": "ecs check --ansi --memory-limit=1G",
		"ecs:fix": "ecs check --ansi --fix --memory-limit=1G",
		"rector:fix": "rector process --config rector.php",
		"rector:dry-run": "rector process --dry-run --config rector.php"
	}
}
